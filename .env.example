# 复制本文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会被提交
# !! 永远不要把 API Key 贴到聊天 / 代码 / git / 任何分享渠道 !!

# ============================================================
# 选一个 backend 取消注释（DMXAPI 中转推荐给中国大陆开发者）
# ============================================================

# --- 选项 A：DMXAPI 中转（国内直连，支付宝充值，无需 VPN，⭐ 中国推荐）---
# 注册：https://www.dmxapi.cn  →  个人中心 → 创建令牌
# 价格：gpt-image-1 ¥1/张，flux-kontext-pro ¥0.2/张，seedream-3.0 ¥0.08/张
OPENAI_API_KEY=sk-填你的DMXAPI令牌
OPENAI_BASE_URL=https://www.dmxapi.cn/v1
OPENAI_IMAGE_MODEL=gpt-image-1
BUDGET_LIMIT_CNY=50.0

# --- 选项 B：OpenAI 官方直连（需要 VPN + 海外信用卡，有封号风险）---
# OPENAI_API_KEY=sk-proj-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_IMAGE_MODEL=gpt-image-2
# BUDGET_LIMIT_USD=80.0

# --- 选项 C：API易（apiyi.com）—— Flux 价格全网最低 ---
# OPENAI_API_KEY=sk-apiyi-xxxx
# OPENAI_BASE_URL=https://api.apiyi.com/v1
# OPENAI_IMAGE_MODEL=flux-kontext-pro
# BUDGET_LIMIT_USD=10.0


# ============================================================
# 流水线参数（所有 backend 通用）
# ============================================================

# 异步并发数（OpenAI Tier 1: 5 IPM，DMXAPI 一般 60 IPM）
GEN_CONCURRENCY=4

# 默认输出尺寸与质量（YAML 模板可覆盖）
DEFAULT_SIZE=1024x1024
DEFAULT_QUALITY=medium

# 失败重试次数（不含首次）
MAX_RETRIES=2


# ============================================================
# 输出路径
# ============================================================
RAW_DIR=assets/raw
PROCESSED_DIR=assets/processed
STYLE_BIBLE_DIR=assets/_style_bible
