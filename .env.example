# 复制本文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会被提交

# === OpenAI GPT Image 2 ===
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
# 如使用第三方代理（如 apiyi）取消注释下面这行
# OPENAI_BASE_URL=https://api.apiyi.com/v1

# === 流水线参数 ===
# 单次运行预算上限（美元），达到自动停止
BUDGET_LIMIT_USD=80.0

# 异步并发数（OpenAI Tier 1 限制 5 IPM，建议 4 留余量）
GEN_CONCURRENCY=4

# 默认输出尺寸与质量（YAML 模板可覆盖）
DEFAULT_SIZE=1024x1024
DEFAULT_QUALITY=medium

# 失败重试次数（不含首次）
MAX_RETRIES=2

# === 输出路径 ===
RAW_DIR=assets/raw
PROCESSED_DIR=assets/processed
STYLE_BIBLE_DIR=assets/_style_bible
